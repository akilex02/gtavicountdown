---
import Layout from "@/layouts/Layout.astro";

import HeroKeyLogo from "@/assets/hero-key-logo.png";
import HeroKeyBackground from "@/assets/Jason_and_Lucia_03_landscape.png";
import LogoVI from "@/assets/logo-vi.svg";
import LogoCutted from "@/assets/logo-cutted.svg";
---

<Layout>
  <div
    id="logo-vi-back"
    class="fixed top-0 w-full h-screen pointer-events-none"
  >
  </div>
  <div id="logo-mask" class="fixed top-0 w-full h-screen">
    <div
      id="hero-key"
      class="w-full h-screen scale-120 block overflow-hidden fixed top-0 left-0"
    >
      <img
        id="hero-key-logo"
        src={HeroKeyLogo.src}
        class="absolute w-full h-full object-cover"
      />
      <img
        id="hero-key-background"
        src={HeroKeyBackground.src}
        class="w-full h-full object-cover"
      />
    </div>
  </div>

  <div
    class="fixed flex flex-col items-center justify-between h-screen px-20 py-16 w-full"
  >
    <header class="flex justify-between w-full">
      <LogoVI
        class="size-11 text-white hover:text-yellow-100 transition-colors duration-500 cursor-pointer"
      />
    </header>

    <footer id="hero-footer" class="absolute bottom-8 m-auto">
      <LogoCutted
        class="text-white w-38 drop-shadow-[0_0_2px_rgba(255,255,255,.5),0_0_8px_#000]"
      />
      <span
        class="absolute uppercase tracking-[6px] whitespace-nowrap text-center top-[49px] font-medium text-shadow-[0_0_2px_rgba(255,255,255,.5),0_0_8px_#000] left-1/2 -translate-x-1/2 text-lg"
      >
        COUNTDOWN
      </span>
    </footer>
  </div>

  <div
    id="countdown-section"
    class="fixed top-[58%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl px-6 flex flex-col items-center justify-center opacity-0 pointer-events-none z-50"
  >
    <p
      class="subtitle-countdown uppercase tracking-[3px] text-xs md:text-sm font-semibold mb-6 text-[#e4dcff] text-center"
    >
      Cuenta regresiva para el lanzamiento
    </p>
    <div class="countdown flex gap-3 md:gap-4 justify-center w-full mb-8">
      <div class="countdown-item">
        <div class="countdown-number" id="days">---</div>
        <div class="countdown-label">Días</div>
      </div>
      <div class="countdown-item">
        <div class="countdown-number" id="hours">--</div>
        <div class="countdown-label">Horas</div>
      </div>
      <div class="countdown-item">
        <div class="countdown-number" id="minutes">--</div>
        <div class="countdown-label">Minutos</div>
      </div>
      <div class="countdown-item">
        <div class="countdown-number" id="seconds">--</div>
        <div class="countdown-label">Segundos</div>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="progress-container w-full max-w-xl rounded-lg">
      <div class="progress-header flex justify-between items-center mb-3">
        <span
          class="progress-title text-[10px] md:text-xs font-semibold tracking-[2px] uppercase text-[#e4dcff]"
          >Progreso hacia el lanzamiento</span
        >
        <span
          class="progress-percentage text-sm md:text-base font-bold text-transparent bg-clip-text"
          id="percentage">0%</span
        >
      </div>
      <div
        class="progress-bar-wrapper h-2 w-full bg-white/5 rounded-full overflow-hidden relative"
      >
        <div
          class="progress-bar h-full w-0 rounded-full transition-[width] duration-1000 ease-out relative"
          id="progress-bar"
        >
        </div>
      </div>
      <div
        class="progress-dates flex justify-between mt-3 text-[10px] md:text-xs text-[#e4dcff] tracking-[1px]"
      >
        <span>Nov 6 2025</span>
        <span>Nov 19 2026</span>
      </div>
    </div>
  </div>
</Layout>

<style>
  #hero-key-logo {
    filter: drop-shadow(0 0 12px rgba(255, 255, 255, 0.5));
  }

  #logo-vi-back {
    background-image: url("/VI-back.png");
    background-size: clamp(20vh, 25%, 25vh);
    background-position: center 25%;
    background-repeat: no-repeat;
    opacity: 0;
    z-index: 10;
  }

  #logo-mask {
    background: white;
    mask-image: url("/logo-stack.svg");
    mask-position: center 25%;
    mask-repeat: no-repeat;
    mask-size: clamp(5500vh, 3500%, 0vh);
    z-index: 20;
  }

  :root {
    --accent-gradient: linear-gradient(
      135deg,
      #685ad1,
      #ca51c1,
      #fe4eb7,
      #f6678d,
      #eb8757
    );
    --accent-pink: #fe4eb7;
    --bg-card: rgba(20, 20, 20, 0.85);
    --border-subtle: rgba(255, 255, 255, 0.08);
    --border-hover: rgba(255, 255, 255, 0.15);
  }

  .countdown-item {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    backdrop-filter: blur(20px);
    padding: 16px 12px;
    min-width: 90px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    flex: 1;
    max-width: 120px;
  }

  @media (min-width: 768px) {
    .countdown-item {
      padding: 24px 20px;
      min-width: 110px;
    }
  }

  .countdown-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent-gradient);
    transform: scaleX(0);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .countdown-item:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .countdown-item:hover::before {
    transform: scaleX(1);
  }

  .countdown-number {
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-variant-numeric: tabular-nums;
  }

  .countdown-label {
    margin-top: 8px;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #e4dcff;
  }

  /* Progress Bar styling */
  .progress-container {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    backdrop-filter: blur(20px);
    padding: 20px;
  }

  .progress-percentage {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .progress-bar {
    background: var(--accent-gradient);
  }

  .progress-bar::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  /* Number flip animation */
  .countdown-number.flip {
    animation: number-flip 0.3s ease;
  }

  @keyframes number-flip {
    0% {
      transform: rotateX(0deg);
    }
    50% {
      transform: rotateX(-10deg) scale(1.05);
    }
    100% {
      transform: rotateX(0deg);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ═══════════════════════════════════════════════════════════════
  // CONFIGURACIÓN COMPARTIDA DEL SCROLLTRIGGER
  // Ambos timelines (mask/UI y video) usan el mismo spacer como
  // trigger para que avancen sincronizados con el mismo scroll.
  // ═══════════════════════════════════════════════════════════════

  const SCROLL_TRIGGER_CONFIG = {
    trigger: "#scroll-spacer",
    start: "top top",
    end: "bottom bottom",
  };

  const tl = gsap.timeline({
    ease: "power2.out",
    scrollTrigger: {
      ...SCROLL_TRIGGER_CONFIG,
      scrub: 1,
    },
  });

  tl.to("#hero-key", { duration: 1, scale: 1 })
    .to("#hero-key-logo", { opacity: 0 }, "<")
    .to("#hero-footer", { opacity: 0 }, "<")
    .to(
      "#logo-mask",
      {
        maskSize: "clamp(20vh, 25%, 30vh)",
      },
      0.15,
    )
    .to(
      "#hero-key",
      {
        opacity: 0,
        duration: 0.2,
      },
      0.3,
    )
    .to(
      "#logo-mask",
      {
        opacity: 0,
        duration: 0.3,
      },
      0.4,
    )
    .to(
      "#logo-vi-back",
      {
        opacity: 1,
        duration: 0.3,
      },
      0.6,
    )
    .to(
      "#countdown-section",
      {
        opacity: 1,
        pointerEvents: "auto",
        duration: 0.3,
      },
      0.55,
    );

  // ═══════════════════════════════════════════════════════════════
  // COUNTDOWN LOGIC
  // ═══════════════════════════════════════════════════════════════

  const releaseDate = new Date("2026-11-19T00:00:00").getTime();
  const startDate = new Date("2025-11-06T00:00:00").getTime();

  const daysEl = document.getElementById("days");
  const hoursEl = document.getElementById("hours");
  const minutesEl = document.getElementById("minutes");
  const secondsEl = document.getElementById("seconds");
  const percentageEl = document.getElementById("percentage");
  const progressBar = document.getElementById("progress-bar");

  // Store previous values for animation
  let prevValues = { days: null, hours: null, minutes: null, seconds: null };

  function padNumber(num, length = 2) {
    return String(num).padStart(length, "0");
  }

  function animateNumber(element, newValue, key) {
    if (prevValues[key] !== newValue) {
      element.classList.add("flip");
      setTimeout(() => element.classList.remove("flip"), 300);
      prevValues[key] = newValue;
    }
  }

  function updateCountdown() {
    if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return;

    const now = Date.now();
    const difference = releaseDate - now;

    if (difference <= 0) {
      daysEl.textContent = "000";
      hoursEl.textContent = "00";
      minutesEl.textContent = "00";
      secondsEl.textContent = "00";
      const subtitle = document.querySelector(".subtitle-countdown");
      if (subtitle)
        subtitle.textContent = "¡Grand Theft Auto VI ya está disponible!";
      return;
    }

    const days = Math.floor(difference / (1000 * 60 * 60 * 24));
    const hours = Math.floor(
      (difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
    );
    const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((difference % (1000 * 60)) / 1000);

    animateNumber(daysEl, days, "days");
    animateNumber(hoursEl, hours, "hours");
    animateNumber(minutesEl, minutes, "minutes");
    animateNumber(secondsEl, seconds, "seconds");

    daysEl.textContent = padNumber(days, 3);
    hoursEl.textContent = padNumber(hours);
    minutesEl.textContent = padNumber(minutes);
    secondsEl.textContent = padNumber(seconds);
  }

  function updateProgress() {
    if (!progressBar || !percentageEl) return;

    const now = Date.now();
    const total = releaseDate - startDate;
    const elapsed = now - startDate;

    let percent = (elapsed / total) * 100;
    percent = Math.min(Math.max(percent, 0), 100);

    progressBar.style.width = percent + "%";
    percentageEl.textContent = percent.toFixed(1) + "%";
  }

  // Initialize
  updateCountdown();
  updateProgress();

  // Update every second
  setInterval(() => {
    updateCountdown();
    updateProgress();
  }, 1000);
</script>
